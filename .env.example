# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (must match POSTGRES_* vars below)
DATABASE_URL=postgres://mainty:mainty@db:5432/mainty

# PostgreSQL service (docker-compose)
POSTGRES_DB=mainty
POSTGRES_USER=mainty
POSTGRES_PASSWORD=mainty
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email (Mailhog for development)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=mainty@localhost

# Admin notifications
ADMINS=Admin:admin@localhost

# Initial admin user (used by create_initial_admin management command)
DJANGO_ADMIN_USER=admin
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_ADMIN_PASSWORD=change-me

# Password rotation (days, default 90)
PASSWORD_EXPIRY_DAYS=90

# Contract warning window (days before expiry, default 90)
CONTRACT_EXPIRY_WARNING_DAYS=90

# Reminder emails
SITE_URL=https://your-domain.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
REMINDER_EMAIL_SUBJECT=[mainty] GMP-Erinnerung — Handlungsbedarf

# Backup
BACKUP_DIR=/var/backups/mainty
BACKUP_RETENTION_DAYS=30
